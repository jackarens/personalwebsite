---
import { Image } from "astro:assets";
import Fragment from "./Fragment.astro";

import layerAppView from "../../assets/layer-app-view.png";
---

<section>
	<h2>About Me</h2>
	<ul>
		<Fragment as="li">2021 UNL &amp; Raikes School graduate (Cohort 2017)</Fragment>
		<Fragment as="li">Engineering @ Layer since graduation</Fragment>
		<Fragment as="li">Live in Lincoln, NE</Fragment>
		<Fragment as="li">Fun Fact: I can ride a unicycle 🦄</Fragment>
	</ul>
</section>

<section>
	<h2>About Layer</h2>
	<div class="r-stack">
		<ul>
			<Fragment as="li">Construction data management platform</Fragment>
			<Fragment as="li">Used by architecture firms and job sites worldwide</Fragment>
		</ul>
		<Image src={layerAppView} alt="Layer logo" class="fragment fade-in-then-out" />
		<video autoplay loop muted playsinline class="fragment">
			<source src="/layer-doc-view.mp4" type="video/mp4" />
		</video>
		<iframe
			class="fragment"
			style="width:100%;height:100%;border:none;border-radius:12px"
			src="https://public.layer.team/view/LZ7XNzTAal925CW6XYpM?hideBorder=true"
			title="🔲 All Rooms"></iframe>
	</div>
</section>
