---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	/** Optional emoji/character shown as a large, faint watermark. */
	glyph?: string;
	/** Accent color for the full-bleed wash. Defaults to the site green. */
	tint?: string;
	/** Optional full-bleed cover image. When set, it replaces the watermark
	 *  and a dark scrim keeps the title legible. Swap in a photo here. */
	image?: ImageMetadata;
	/** Alt text for the image (decorative backgrounds can leave this blank). */
	alt?: string;
}

const { glyph = "", tint = "#228B22", image, alt = "" } = Astro.props;
---

<div class="section-bg" aria-hidden={image ? undefined : "true"} style={`--tint:${tint}`}>
	{
		image ? (
			<>
				<Image class="section-bg-img" src={image} alt={alt} />
				<div class="section-bg-scrim" />
			</>
		) : (
			glyph && <span class="section-bg-glyph">{glyph}</span>
		)
	}
</div>

<style is:global>
	/* Benign: makes the section a positioning context and clips the wash. */
	.reveal section.section-header {
		position: relative;
		overflow: hidden;
	}
</style>

<style>
	.section-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(
				90% 85% at 50% 32%,
				color-mix(in srgb, var(--tint) 26%, transparent),
				transparent 72%
			),
			linear-gradient(155deg, color-mix(in srgb, var(--tint) 12%, transparent), transparent 58%);
	}

	.section-bg-glyph {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		font-size: 26rem;
		line-height: 1;
		opacity: 0.08;
		user-select: none;
	}

	.section-bg-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Dark scrim so the accent title stays readable over any photo. */
	.section-bg-scrim {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(80% 70% at 50% 45%, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.72));
	}
</style>
